{
  // Static-assets-only Worker: no server code, just serves the built site.
  // `npm run build` emits ./dist, and `npx wrangler deploy` uploads it.
  "name": "egge-us-site",
  "compatibility_date": "2026-06-05",
  "assets": {
    "directory": "./dist"
  },
  // Serve the site on the apex and www (both as custom domains on the Worker).
  "routes": [
    { "pattern": "egge.us", "custom_domain": true },
    { "pattern": "www.egge.us", "custom_domain": true }
  ]
}
