---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Mark Egge: Applied data science & transportation planning',
  description = 'Mark Egge is an applied data scientist and transportation planner in Bozeman, Montana, who ships production software, turning messy public-sector data into tools people actually use.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://egge.us').href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon-monogram.svg" />

    <!-- preload self-hosted variable fonts used above the fold -->
    <link
      rel="preload"
      href="/fonts/Nunito/Nunito-VariableFont_wght.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Inter/Inter-VariableFont_opsz,wght.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <slot />

    <script>
      // Subtle header rule once you start scrolling.
      (function () {
        const header = document.getElementById('siteHeader');
        if (!header) return;
        const el = header;
        const onScroll = function () {
          el.classList.toggle('scrolled', window.scrollY > 12);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>

    <script>
      // Konami code + Mortal Kombat fatalities → hidden arcade.
      // Self-contained, no UI until triggered.
      (function () {
        // ── Keyboard mapping for SNES Mortal Kombat (MK1/MK2) inputs ──
        //   Directions:  Back = ArrowLeft, Forward = ArrowRight,
        //                Up = ArrowUp, Down = ArrowDown
        //   Buttons:     High Punch = KeyY, Low Punch = KeyT,
        //                High Kick  = KeyU, Low Kick  = KeyH,
        //                Block      = KeyB, Run       = KeyR
        const BACK = 'ArrowLeft', FWD = 'ArrowRight', UP = 'ArrowUp', DOWN = 'ArrowDown';
        const HP = 'KeyY', LP = 'KeyT', HK = 'KeyU', LK = 'KeyH', BL = 'KeyB', RUN = 'KeyR';

        // Each trigger is a list of e.code values matched against the trailing keystrokes.
        const triggers = [
          // Konami code (kept).
          [UP, UP, DOWN, DOWN, BACK, FWD, BACK, FWD, 'KeyB', 'KeyA'],

          // ── Classic Mortal Kombat fatalities ──
          // Sub-Zero (MK1) — Spine Rip: Forward, Down, Forward, High Punch.
          [FWD, DOWN, FWD, HP],
          // Scorpion (MK1) — Toasty! (fire breath): Down, Down, Up.
          [DOWN, DOWN, UP],
          // Kano (MK1) — Heart Rip: Back, Down, Forward, Low Punch.
          [BACK, DOWN, FWD, LP],
          // Johnny Cage (MK1) — Torso Rip: Forward, Forward, Down, Low Punch.
          [FWD, FWD, DOWN, LP],
          // Raiden (MK1) — Electrocution: Down, Up, Left, Right, Block.
          [DOWN, UP, BACK, FWD, BL],
          // Liu Kang (MK2) — Dragon Bite: Forward, Forward, Down, Down.
          [FWD, FWD, DOWN, DOWN],
          // Reptile (MK2) — Tongue: Down, Forward, Forward, High Punch (then more).
          [DOWN, FWD, FWD, HP],
          // Jax (MK2) — Arm Rip: Forward, Forward, Back, Back, Low Punch.
          [FWD, FWD, BACK, BACK, LP],
          // Kung Lao (MK2) — Hat Throw: Run, Block, High Kick (run-range).
          [RUN, BL, HK],
          // Mileena (MK2) — Sai Throw: Back, Forward, Down, High Kick (close).
          [BACK, FWD, DOWN, HK],
          // Baraka (MK2) — Blade Lift: Back, Back, Back, Low Kick.
          [BACK, BACK, BACK, LK],
        ];
        const maxLen = Math.max(...triggers.map((t) => t.length));
        const recent: string[] = [];

        let overlay: HTMLDivElement | null = null;

        function closeArcade() {
          if (overlay) {
            overlay.remove();
            overlay = null;
            document.removeEventListener('keydown', onEsc, true);
          }
        }
        function onEsc(e: KeyboardEvent) {
          if (e.key === 'Escape') {
            e.stopPropagation();
            closeArcade();
          }
        }
        function openArcade() {
          if (overlay) return;
          overlay = document.createElement('div');
          overlay.setAttribute('role', 'dialog');
          overlay.setAttribute('aria-label', 'Hidden arcade');
          Object.assign(overlay.style, {
            position: 'fixed', inset: '0', zIndex: '2147483647',
            background: 'rgba(0,0,0,0.88)', display: 'flex',
            alignItems: 'center', justifyContent: 'center',
          });

          const frame = document.createElement('iframe');
          frame.src = '/arcade/';
          frame.title = "Clippy's Slop Blaster";
          Object.assign(frame.style, {
            width: '92vw', height: '88vh', maxWidth: '900px',
            border: '0', borderRadius: '8px',
            boxShadow: '0 12px 60px rgba(0,0,0,0.6)', background: '#008080',
          });
          // Same-origin iframe: focus it once loaded so keyboard input (arrows,
          // Enter, space) reaches the game instead of scrolling the page behind.
          frame.addEventListener('load', function () {
            frame.focus();
            frame.contentWindow?.focus();
          });

          const close = document.createElement('button');
          close.type = 'button';
          close.setAttribute('aria-label', 'Close arcade');
          close.textContent = '✕';
          Object.assign(close.style, {
            position: 'absolute', top: '16px', right: '20px',
            width: '40px', height: '40px', borderRadius: '50%',
            border: '0', cursor: 'pointer', fontSize: '20px',
            lineHeight: '40px', background: '#fff', color: '#111',
            boxShadow: '0 2px 10px rgba(0,0,0,0.4)',
          });
          close.addEventListener('click', closeArcade);

          overlay.appendChild(frame);
          overlay.appendChild(close);
          overlay.addEventListener('click', function (e: MouseEvent) {
            if (e.target === overlay) closeArcade();
          });
          // A click/tap anywhere on the overlay re-grabs focus into the game.
          overlay.addEventListener('pointerdown', function (e: PointerEvent) {
            if (e.target !== close) {
              frame.focus();
              frame.contentWindow?.focus();
            }
          });
          document.body.appendChild(overlay);
          document.addEventListener('keydown', onEsc, true);
          frame.focus();
          frame.contentWindow?.focus();
        }

        function endsWith(seq: string[]): boolean {
          if (recent.length < seq.length) return false;
          const off = recent.length - seq.length;
          for (let i = 0; i < seq.length; i++) {
            if (recent[off + i] !== seq[i]) return false;
          }
          return true;
        }

        document.addEventListener('keydown', function (e: KeyboardEvent) {
          if (overlay) return;
          const t = e.target as HTMLElement | null;
          if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;

          recent.push(e.code);
          if (recent.length > maxLen) recent.shift();

          if (triggers.some(endsWith)) {
            recent.length = 0;
            openArcade();
          }
        });

        // ── Mobile trigger: long-press the ME monogram brand mark ──
        // Keyboard codes (Konami/MK) don't exist on phones, so on touch
        // devices a ~800ms press-and-hold on the logo opens the same overlay.
        // A short tap still navigates home; only a fired long-press is suppressed.
        const isTouch =
          matchMedia('(pointer: coarse)').matches || 'ontouchstart' in window;
        if (isTouch) {
          const brand = document.querySelector<HTMLElement>('.brand, .brand-mark');
          if (brand) {
            let holdTimer: number | null = null;
            let longFired = false;
            const HOLD_MS = 800;

            const startHold = function () {
              longFired = false;
              if (holdTimer !== null) clearTimeout(holdTimer);
              holdTimer = window.setTimeout(function () {
                longFired = true;
                holdTimer = null;
                openArcade();
              }, HOLD_MS);
            };
            const cancelHold = function () {
              if (holdTimer !== null) {
                clearTimeout(holdTimer);
                holdTimer = null;
              }
            };

            brand.addEventListener('touchstart', startHold, { passive: true });
            brand.addEventListener('touchend', cancelHold);
            brand.addEventListener('touchmove', cancelHold, { passive: true });
            brand.addEventListener('touchcancel', cancelHold);
            // Suppress the navigating click ONLY when the long-press fired.
            brand.addEventListener(
              'click',
              function (e: MouseEvent) {
                if (longFired) {
                  e.preventDefault();
                  e.stopPropagation();
                  longFired = false;
                }
              },
              true
            );
          }
        }
      })();
    </script>
  </body>
</html>
