    <circle cx="60" cy="48" r="10" fill="#2E4A3B"></circle>
    <circle cx="120" cy="40" r="8" fill="#8A9A7B"></circle>
    <circle cx="84" cy="104" r="8" fill="#8A9A7B"></circle>
