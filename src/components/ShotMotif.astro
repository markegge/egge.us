      <rect x="132" y="22" width="50" height="34" rx="4" fill="#2E4A3B" opacity="0.3"></rect>
      <rect x="188" y="22" width="50" height="34" rx="4" fill="#8A9A7B" opacity="0.35"></rect>
      <rect x="20" y="62" width="50" height="34" rx="4" fill="#8A9A7B" opacity="0.4"></rect>
      <rect x="76" y="62" width="50" height="34" rx="4" fill="#2E4A3B" opacity="0.45"></rect>
