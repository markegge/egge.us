    <rect x="80" y="60" width="42" height="6" rx="3" fill="#8A9A7B" opacity="0.6"></rect>
    <rect x="80" y="74" width="48" height="6" rx="3" fill="#8A9A7B" opacity="0.45"></rect>
    <rect x="80" y="88" width="34" height="6" rx="3" fill="#8A9A7B" opacity="0.45"></rect>
