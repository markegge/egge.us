---
/**
 * Placeholder product-screenshot motifs, keyed by `image_kind`.
 * These are intentional placeholders until real product screenshots arrive
 * (per the design handoff). All are decorative → aria-hidden.
 *
 *  Feature motifs:  civiccast (audio waveform), gtfsx (route arc + stops over
 *  a grid), transitpeers (bars + coral trend line), suncloud (choropleth tiles
 *  + coral pin), tpm (code window).
 *  Compact/tentative motifs: network (nodes + edges), mapform (map pin on a
 *  form), docs (stacked documents).
 */
interface Props {
  kind: string;
}
const { kind } = Astro.props;
---

{kind === 'civiccast' && (
  <svg viewBox="0 0 260 92" aria-hidden="true">
    <circle cx="28" cy="46" r="19" fill="#2E4A3B"></circle>
    <path d="M23 37 L38 46 L23 55 Z" fill="#F6F2E8"></path>
    <g>
      <rect x="64" y="35" width="6" height="22" rx="3" fill="#2E4A3B" opacity="0.5"></rect>
      <rect x="76" y="24" width="6" height="44" rx="3" fill="#2E4A3B" opacity="0.7"></rect>
      <rect x="88" y="30" width="6" height="32" rx="3" fill="#8A9A7B"></rect>
      <rect x="100" y="16" width="6" height="60" rx="3" fill="#2E4A3B"></rect>
      <rect x="112" y="34" width="6" height="24" rx="3" fill="#8A9A7B"></rect>
      <rect x="124" y="22" width="6" height="48" rx="3" fill="#2E4A3B" opacity="0.7"></rect>
      <rect x="136" y="38" width="6" height="16" rx="3" fill="#8A9A7B"></rect>
      <rect x="148" y="26" width="6" height="40" rx="3" fill="#2E4A3B"></rect>
      <rect x="160" y="32" width="6" height="28" rx="3" fill="#8A9A7B"></rect>
      <rect x="172" y="18" width="6" height="56" rx="3" fill="#2E4A3B" opacity="0.7"></rect>
      <rect x="184" y="36" width="6" height="20" rx="3" fill="#8A9A7B"></rect>
      <rect x="196" y="28" width="6" height="36" rx="3" fill="#2E4A3B"></rect>
      <rect x="208" y="40" width="6" height="12" rx="3" fill="#8A9A7B"></rect>
      <rect x="220" y="30" width="6" height="32" rx="3" fill="#2E4A3B" opacity="0.5"></rect>
      <rect x="232" y="38" width="6" height="16" rx="3" fill="#8A9A7B"></rect>
    </g>
  </svg>
)}

{kind === 'gtfsx' && (
