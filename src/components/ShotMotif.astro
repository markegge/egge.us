      <line x1="0" y1="114" x2="260" y2="114"></line>
      <line x1="66" y1="0" x2="66" y2="150"></line>
      <line x1="132" y1="0" x2="132" y2="150"></line>
      <line x1="198" y1="0" x2="198" y2="150"></line>
    </g>
    <path d="M22 126 C72 126, 84 34, 138 38 S224 104, 240 44" stroke="#2E4A3B" stroke-width="4.5" fill="none" stroke-linecap="round"></path>
    <circle cx="22" cy="126" r="6" fill="#fff" stroke="#2E4A3B" stroke-width="3.5"></circle>
    <circle cx="84" cy="62" r="6" fill="#fff" stroke="#2E4A3B" stroke-width="3.5"></circle>
    <circle cx="138" cy="38" r="6" fill="#E8734A" stroke="#fff" stroke-width="3"></circle>
    <circle cx="192" cy="86" r="6" fill="#fff" stroke="#2E4A3B" stroke-width="3.5"></circle>
    <circle cx="240" cy="44" r="6" fill="#fff" stroke="#2E4A3B" stroke-width="3.5"></circle>
  </svg>
)}

